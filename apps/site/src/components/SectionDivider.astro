---
import Khatam from './Khatam.astro';
---

<div class="section-divider" aria-hidden="true">
	<span class="section-divider__line"></span>
	<Khatam size="0.95rem" opacity={0.85} />
	<span class="section-divider__line"></span>
</div>

<style>
	.section-divider {
		display: flex;
		align-items: center;
		gap: 0.85rem;
		max-width: 72rem;
		margin: 0 auto;
		padding: 0 1.25rem;
	}

	.section-divider__line {
		flex: 1;
		height: 1px;
		background: linear-gradient(90deg, transparent, color-mix(in srgb, var(--gold) 35%, #292524) 50%, transparent);
	}
</style>
