---
interface Props {
	class?: string;
}

const { class: className } = Astro.props;
---

<p class:list={['etymology', className]}>
	<span>dastan</span>
	<span class="etymology__sep" aria-hidden="true">·</span>
	<span class="etymology__persian" dir="rtl" lang="fa">داستان</span>
	<span class="etymology__sep" aria-hidden="true">·</span>
	<span>Persian, an epic tale</span>
</p>

<style>
	.etymology {
		margin: 0;
		font-size: 0.78rem;
		letter-spacing: 0.04em;
		color: var(--text-muted);
		display: flex;
		flex-wrap: wrap;
		align-items: baseline;
		gap: 0.35rem;
	}

	.etymology__sep {
		opacity: 0.45;
	}

	.etymology__persian {
		font-family: 'Noto Naskh Arabic', 'Geeza Pro', serif;
		font-size: 0.92em;
		letter-spacing: 0;
	}
</style>
