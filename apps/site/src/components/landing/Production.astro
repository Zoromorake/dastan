---
import CapturePlaceholder from '../CapturePlaceholder.astro';
import { khatamSvgMarkup } from '../../lib/khatam';

const revisions = [
	{ color: 'var(--revision-white)', label: 'White' },
	{ color: 'var(--revision-blue)', label: 'Blue' },
	{ color: 'var(--revision-pink)', label: 'Pink' },
	{ color: 'var(--revision-yellow)', label: 'Yellow' },
	{ color: 'var(--revision-green)', label: 'Green' },
	{ color: 'var(--revision-goldenrod)', label: 'Goldenrod' },
];

const features = [
	'Locked scene numbers with A-scenes (A13, B13…)',
	'OMITTED scenes',
	'Change marks against revision baselines',
	'Scene, character, and location reports',
	'PDF and FDX export with revision options',
];

const khatamMarker = `url("data:image/svg+xml,${encodeURIComponent(khatamSvgMarkup({ opacity: 0.85, color: '#c9a227' }))}")`;
---

<section class="production reveal" id="production">
	<p class="slugline section-slug">INT. PRODUCTION OFFICE - DAY</p>
	<h2 class="section-title">Production-minded formatting</h2>

	<div class="production__strip" role="list" aria-label="Revision set colors">
		{
			revisions.map((rev) => (
				<div class="production__swatch" style={`--swatch: ${rev.color}`} role="listitem">
					<span class="production__swatch-color" />
					<span>{rev.label}</span>
				</div>
			))
		}
	</div>

	<ul class="production__list" style={`--khatam-marker: ${khatamMarker}`}>
		{features.map((feature) => <li>{feature}</li>)}
	</ul>

	<div class="production__crop">
		<!--
			ARIF: capture revision mode with colored border + margin change marks on a short scene,
			or PDF export dialog with revision options, dark UI, paper page visible
		-->
		<CapturePlaceholder name="Revision marks" />
	</div>
</section>

<style>
	.production {
		padding: 4rem 1.25rem;
		max-width: 72rem;
		margin: 0 auto;
	}

	.production__strip {
		display: flex;
		flex-wrap: wrap;
		gap: 0.65rem;
		margin-bottom: 1.5rem;
	}

	.production__swatch {
		display: flex;
		align-items: center;
		gap: 0.45rem;
		padding: 0.35rem 0.65rem;
		border-radius: 999px;
		border: 1px solid #2a3158;
		background: var(--ink-soft);
		font-size: 0.78rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
	}

	.production__swatch-color {
		width: 0.85rem;
		height: 0.85rem;
		border-radius: 999px;
		background: var(--swatch);
		border: 1px solid rgba(255, 255, 255, 0.15);
	}

	.production__list {
		margin: 0 0 1.25rem;
		padding-left: 0;
		list-style: none;
		color: #d6d3d1;
		display: grid;
		gap: 0.45rem;
	}

	.production__list li {
		display: flex;
		align-items: flex-start;
		gap: 0.55rem;
		padding-left: 0.15rem;
	}

	.production__list li::before {
		content: '';
		flex-shrink: 0;
		width: 0.75rem;
		height: 0.75rem;
		margin-top: 0.2rem;
		background-image: var(--khatam-marker);
		background-size: contain;
		background-repeat: no-repeat;
		background-position: center;
		color: var(--gold);
	}

	.production__crop {
		aspect-ratio: 21 / 9;
		border: 1px solid #2a3158;
		border-radius: 0.35rem;
		background: var(--ink-soft);
		overflow: hidden;
	}
</style>
