---
import { HeroEditor } from '../HeroEditor';
import CapturePlaceholder from '../CapturePlaceholder.astro';
import { GITHUB_STARS_THRESHOLD } from '../../lib/site-config';
import type { SiteLinks } from '../../lib/types';

interface Props {
	links: SiteLinks;
	stars: number;
}

const { links, stars } = Astro.props;
const showStars = stars >= GITHUB_STARS_THRESHOLD;
---

<section class="hero reveal">
	<div class="hero__inner">
		<p class="slugline">INT. YOUR SCRIPT - NIGHT</p>
		<h1 class="hero__title">Write the script.<br />Keep the script.</h1>
		<p class="hero__sub">
			Free, open-source, local-first screenwriting with AI on your own API key. Your pages stay private by default.
		</p>
		<div class="hero__ctas">
			<a class="btn btn--primary" href={links.appUrl}>Start writing free</a>
			<a class="btn btn--ghost" href={links.repoUrl} rel="noreferrer" target="_blank">
				GitHub
				{showStars && (
					<span class="hero__stars" aria-label={`${stars} stars`}>
						★ {stars}
					</span>
				)}
			</a>
		</div>
	</div>

	<div class="hero__editor hero__editor--desktop">
		<HeroEditor client:visible />
	</div>

	<div class="hero__editor hero__editor--mobile">
		<!--
			ARIF: screen-record 15s of typing in the real editor, Tab/Enter flow, dark ink UI around bright page,
			original sample scene, export as webm ~640px wide, place at public/hero-demo.webm
		-->
		<div class="hero__video-frame">
			<CapturePlaceholder name="Editor demo" />
		</div>
	</div>
</section>

<style>
	.hero {
		padding: 4rem 1.25rem 3rem;
		max-width: 72rem;
		margin: 0 auto;
	}

	.hero__inner {
		max-width: 40rem;
		margin-bottom: 2.5rem;
	}

	.hero__title {
		font-family: 'Courier Prime', Courier New, monospace;
		font-size: clamp(2.2rem, 6vw, 3.6rem);
		font-weight: 700;
		line-height: 1.08;
		letter-spacing: -0.02em;
		margin: 0.75rem 0 1rem;
		color: var(--paper-bright);
	}

	.hero__sub {
		font-size: 1.05rem;
		color: #d6d3d1;
		max-width: 34rem;
		margin: 0 0 1.75rem;
	}

	.hero__ctas {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
	}

	.hero__editor--mobile {
		display: none;
	}

	.hero__video-frame {
		aspect-ratio: 16 / 10;
		border: 1px solid #2a3158;
		border-radius: 0.35rem;
		background: var(--ink-soft);
		overflow: hidden;
	}

	@media (max-width: 768px) {
		.hero__editor--desktop {
			display: none;
		}

		.hero__editor--mobile {
			display: block;
		}
	}
</style>
