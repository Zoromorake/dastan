---
import type { SiteLinks } from '../../lib/types';

interface Props {
	links: SiteLinks;
	current?: 'home' | 'about';
}

const { links, current } = Astro.props;
---

<header class="top-nav">
	<a class="top-nav__logo" href="/">
		<span aria-hidden="true">▌</span> Dastan
	</a>
	<nav class="top-nav__links" aria-label="Primary">
		<a href="/about" aria-current={current === 'about' ? 'page' : undefined}>About</a>
		<a href={links.docsUrl}>Docs</a>
		<a href={links.repoUrl} rel="noreferrer" target="_blank">GitHub</a>
		<a class="top-nav__cta" href={links.appUrl}>Open app</a>
	</nav>
</header>

<style>
	.top-nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 1rem 1.25rem;
		max-width: 72rem;
		margin: 0 auto;
	}

	.top-nav__logo {
		font-family: 'Courier Prime', monospace;
		font-weight: 700;
		text-decoration: none;
		letter-spacing: 0.06em;
	}

	.top-nav__links {
		display: flex;
		align-items: center;
		gap: 1rem;
		font-size: 0.88rem;
	}

	.top-nav__links a {
		text-decoration: none;
		color: #d6d3d1;
	}

	.top-nav__links a[aria-current='page'] {
		color: var(--paper-bright);
	}

	.top-nav__cta {
		padding: 0.4rem 0.75rem;
		border-radius: 0.35rem;
		background: var(--revision-yellow);
		color: #0b1026 !important;
		font-weight: 600;
	}
</style>
